{
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "build",
  "rewrites": [
    {
      "source": "/vertex/api/(.*)",
      "destination": "https://api.maixed.com/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://api.maixed.com/$1"
    },
    {
      "source": "/vertex/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/vertex",
      "destination": "/index.html"
    }
  ]
}
